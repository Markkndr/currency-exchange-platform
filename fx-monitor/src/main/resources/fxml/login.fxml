<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.currencyexchange.ui.controller.LoginController"
      styleClass="root-pane"
      alignment="CENTER"
      prefWidth="420" prefHeight="520">

    <VBox styleClass="auth-card" spacing="16" maxWidth="340.0" alignment="TOP_CENTER">

        <Label text="FX Monitor" styleClass="app-title"/>
        <Label text="Sign in to your account" styleClass="subtitle"/>

        <VBox spacing="6">
            <Label text="EMAIL" styleClass="field-label"/>
            <TextField fx:id="emailField" promptText="you@example.com" styleClass="input-field"/>
        </VBox>

        <VBox spacing="6">
            <Label text="PASSWORD" styleClass="field-label"/>
            <PasswordField fx:id="passwordField" promptText="Enter your password" styleClass="input-field"/>
        </VBox>

        <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>

        <Button fx:id="loginButton" text="Log In" styleClass="primary-button"
                maxWidth="Infinity" onAction="#handleLogin"/>

        <HBox alignment="CENTER" spacing="4">
            <Label text="Need an account?" styleClass="muted-text"/>
            <Hyperlink text="Register" styleClass="link-text" onAction="#navigateToRegister"/>
        </HBox>

    </VBox>
</VBox>
